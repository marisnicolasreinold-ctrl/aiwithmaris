# Stripe — Werte in Vercel unter Settings → Environment Variables setzen.
# Den Secret Key NIEMALS committen oder im Frontend verwenden.
STRIPE_SECRET_KEY=sk_test_...

# Optional: Preis-IDs überschreiben (Standardwerte sind im Code hinterlegt)
# STRIPE_PRICE_DE=price_...
# STRIPE_PRICE_EN=price_...
# STRIPE_PRICE_BUNDLE=price_...
